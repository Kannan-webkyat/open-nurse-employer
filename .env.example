# Copy to .env.local for local dev. Rebuild after changing NEXT_PUBLIC_*.

NEXT_PUBLIC_API_URL=http://localhost:8000

# Must match open-nurses-api APP_TIMEZONE (IANA name, e.g. Europe/London).
NEXT_PUBLIC_APP_TIMEZONE=Europe/London

# Optional: URL encoded in the header profile QR (scan opens this page). Defaults to the portal origin.
# NEXT_PUBLIC_EMPLOYER_QR_REDIRECT_URL=https://example.com/dashboard
